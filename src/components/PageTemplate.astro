---
// src/components/PageTemplate.astro
// MATCHES coach.noahstjohn.com style + adds FAQ + About Noah blocks (build standard).
// LOCKED: "Check Availability" nav CTA. LOCKED testimonials.
// CTAs: nav + hero -> noahstjohn.com | bottom -> noahstjohn.com/consulting
// Buttons (.btn-gold, .btn-nav) MUST be defined here in scoped CSS, not in Base.astro.

const { topic, niche, faq, aboutText } = Astro.props;
// Lowercase a label while preserving all-caps tokens (CEO, CFO, CMO, etc.).
function smartLower(label) {
  if (!label) return label;
  return String(label).split(' ').map(w => /^[A-Z]{2,}[®™]?$/.test(w) ? w : w.toLowerCase()).join(' ');
}
const currentYear = new Date().getFullYear();

const pageTitle = niche ? `${topic.label} for ${niche.label}` : topic.label;
const topicLower = smartLower(topic.label);
const subhead = niche
  ? `Dr. Noah St. John is known worldwide as The Neural Performance Architect. If you lead ${smartLower(niche.label)} and you are searching for ${topicLower}, the strategy is not the problem. The Invisible Brake™ is.`
  : `Dr. Noah St. John is known worldwide as The Neural Performance Architect. If you are a veterinarian, veterinary practice owner, or multi-location veterinary group leader searching for ${topicLower}, the strategy is not the problem. The Invisible Brake™ is.`;
---
<style>
:root{--gold:#B8952A;--gold-light:#D4AF50;--gold-pale:#F7F1DF;--black:#1A1A1A;--charcoal:#2D2D2D;--mid:#555;--light:#888;--rule:#E0D5C0;--bg:#FAFAF7;--white:#FFFFFF}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--black);font-family:'DM Sans',sans-serif;font-size:17px;line-height:1.8;-webkit-font-smoothing:antialiased}
a{color:inherit}

/* NAV */
.nav{background:var(--white);border-bottom:2px solid var(--gold);position:sticky;top:0;z-index:50;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:64px}
.nav-brand{text-decoration:none;display:flex;align-items:center;gap:10px}
.nav-name{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--black);letter-spacing:-.01em}
.nav-tag{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);font-weight:600}
@media(max-width:600px){.nav-tag{display:none}}
.nav-links{display:flex;align-items:center;gap:6px}
.nav-link{font-size:13px;color:var(--mid);text-decoration:none;padding:6px 12px;font-weight:500}
@media(max-width:700px){.nav-link{display:none}}

/* NAV CTA BUTTON (scoped: beats a{color:inherit} via class+attr specificity) */
.btn-nav{font-size:13px;font-weight:700;color:var(--white);background:var(--gold);text-decoration:none;padding:8px 18px;letter-spacing:.05em;text-transform:uppercase;transition:background .2s;white-space:nowrap;display:inline-block}
.btn-nav:hover{background:var(--black);color:var(--white)}

/* GOLD CTA BUTTON (hero, bottom CTA, footer) */
.btn-gold{display:inline-block;background:var(--gold);color:var(--white);text-decoration:none;font-weight:700;font-size:13px;letter-spacing:.08em;text-transform:uppercase;padding:16px 40px;transition:background .2s,transform .15s;white-space:nowrap}
.btn-gold:hover{background:var(--black);color:var(--white);transform:translateY(-1px)}
@media(max-width:480px){.btn-gold{font-size:11px;padding:14px 20px;letter-spacing:.04em}}

/* HERO */
.hero{background:var(--white);border-bottom:1px solid var(--rule);padding:72px 24px 64px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--gold),var(--gold-light),var(--gold))}
.hero-eyebrow{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:20px}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,5.5vw,62px);font-weight:700;line-height:1.08;color:var(--black);letter-spacing:-.02em;margin-bottom:22px;max-width:820px;margin-left:auto;margin-right:auto}
.hero h1 em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:clamp(16px,2vw,19px);color:var(--mid);max-width:640px;margin:0 auto 36px;line-height:1.7}
.hero-note{font-size:13px;color:var(--light);font-style:italic;margin-top:14px}

/* PAGE WRAP */
.page-wrap{max-width:900px;margin:0 auto;padding:0 24px}

/* SECTIONS */
.content-section{padding:52px 0;border-bottom:1px solid var(--rule)}
.section-label{font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:14px}
h2{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,3.5vw,38px);font-weight:700;line-height:1.15;color:var(--black);margin-bottom:22px;letter-spacing:-.01em}
h2 em{font-style:italic;color:var(--gold)}
p{color:var(--charcoal);line-height:1.82;margin-bottom:18px}
p:last-child{margin-bottom:0}
strong{font-weight:600;color:var(--black)}

.pull-quote{border-left:4px solid var(--gold);background:var(--gold-pale);padding:20px 26px;margin:28px 0;font-family:'Cormorant Garamond',serif;font-size:clamp(17px,2vw,21px);font-style:italic;color:var(--black);line-height:1.5}

/* CHECK LIST */
.check-list{list-style:none;margin:18px 0}
.check-list li{padding:10px 0 10px 32px;position:relative;border-bottom:1px solid var(--rule);color:var(--charcoal);font-size:16px;line-height:1.65}
.check-list li:last-child{border-bottom:none}
.check-list li::before{content:'\2713';position:absolute;left:0;top:11px;color:var(--gold);font-weight:700}

/* TESTIMONIALS */
.testi-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:26px}
@media(max-width:580px){.testi-grid{grid-template-columns:1fr}}
.testi-card{background:var(--white);border:1px solid var(--rule);border-top:3px solid var(--gold);padding:24px 20px 20px}
.testi-stars{color:var(--gold);font-size:12px;letter-spacing:3px;margin-bottom:12px}
.testi-quote{font-family:'Cormorant Garamond',serif;font-size:15px;font-style:italic;color:var(--charcoal);line-height:1.65;margin-bottom:14px}
.testi-name{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--black);margin-bottom:2px}
.testi-title{font-size:12px;color:var(--light)}

/* FAQ SECTION */
.faq-section{background:var(--bg);padding:52px 0;border-bottom:1px solid var(--rule)}
.faq-inner{max-width:900px;margin:0 auto;padding:0 24px}
.faq-list{margin-top:24px;list-style:none;padding:0}
.faq-item{background:var(--white);border:1px solid var(--rule);border-left:3px solid var(--gold);padding:22px 26px;margin-bottom:14px}
.faq-q{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--black);margin-bottom:10px;line-height:1.35}
.faq-a{font-size:16px;color:var(--charcoal);line-height:1.75}

/* ABOUT NOAH (AI SUMMARY) BLOCK */
.ai-summary{background:var(--gold-pale);padding:48px 0;border-bottom:1px solid var(--rule)}
.ai-summary-inner{max-width:900px;margin:0 auto;padding:0 24px}
.ai-summary-label{font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:14px}
.ai-summary-text{font-size:17px;color:var(--black);line-height:1.82;font-family:'DM Sans',sans-serif}

/* BOTTOM CTA */
.cta-section{background:var(--white);border-top:3px solid var(--gold);padding:68px 40px;text-align:center}
.cta-section h2{font-size:clamp(26px,4vw,42px);margin-bottom:14px}
.cta-sub{font-size:17px;color:var(--mid);max-width:500px;margin:0 auto 36px;line-height:1.7}
.cta-url{font-size:13px;color:var(--light);margin-top:10px;display:block}
.cta-divider{display:flex;align-items:center;gap:16px;margin:36px 0 0}
.cta-divider::before,.cta-divider::after{content:'';flex:1;height:1px;background:var(--rule)}
.cta-divider span{color:var(--gold)}
.cta-signoff{font-family:'Cormorant Garamond',serif;font-size:15px;font-style:italic;color:var(--light);margin-top:22px}

/* FOOTER RESULTS BLOCK */
.footer-results{background:var(--black);border-top:3px solid var(--gold);padding:52px 0 44px;text-align:center}
.footer-results-label{font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:28px}
.footer-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;max-width:800px;margin:0 auto 36px;padding:0 24px}
@media(max-width:600px){.footer-stats{grid-template-columns:repeat(2,1fr)}}
.footer-stat-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:700;color:var(--white);line-height:1}
.footer-stat-label{font-size:12px;color:rgba(255,255,255,.5);margin-top:6px}

/* SITE FOOTER */
.site-footer{background:var(--white);border-top:1px solid var(--rule);padding:52px 0 0}
.footer-main{max-width:1200px;margin:0 auto;padding:0 24px 40px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;border-bottom:1px solid var(--rule)}
@media(max-width:800px){.footer-main{grid-template-columns:1fr 1fr}}
@media(max-width:500px){.footer-main{grid-template-columns:1fr}}
.footer-brand-name{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--black);margin-bottom:6px}
.footer-brand-tag{font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:14px}
.footer-brand-desc{font-size:14px;color:var(--mid);line-height:1.7}
.footer-col-label{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:700;border-bottom:2px solid var(--gold-pale);padding-bottom:8px;margin-bottom:14px}
.footer-col-links{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px}
.footer-col-links a{font-size:14px;color:var(--mid);text-decoration:none}
.footer-col-links a:hover{color:var(--gold)}
.footer-signoff-wrap{background:var(--gold-pale);border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);padding:20px 24px;text-align:center}
.footer-signoff{font-family:'Cormorant Garamond',serif;font-size:17px;font-style:italic;color:var(--mid);line-height:1.6}
.footer-bottom{max-width:1200px;margin:0 auto;padding:18px 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
.footer-copy,.footer-bottom-links{font-size:13px;color:var(--light)}
.footer-bottom-links a{color:var(--gold);text-decoration:none;font-weight:600}
.footer-bottom-links a:hover{color:var(--black)}

@media(max-width:600px){.cta-section{padding:52px 22px}}
</style>

<!-- NAV -->
<nav class="nav">
  <div class="nav-inner">
    <a href="https://noahstjohn.com" class="nav-brand">
      <span class="nav-name">Dr. Noah St. John</span>
      <span class="nav-tag">Neural Performance Architect</span>
    </a>
    <div class="nav-links">
      <a href="https://noahstjohn.com" class="nav-link">Home</a>
      <a href="https://noahstjohn.com/consulting" class="nav-link">Consulting</a>
      <a href="https://booknoah.com" class="nav-link">Speaking</a>
      <a href="https://noahstjohn.com" class="btn-nav">Check Availability</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="hero-eyebrow">Dr. Noah St. John | Neural Performance Architect | Worldwide</div>
  <h1><em>{pageTitle}</em></h1>
  <p class="hero-sub">{subhead}</p>
  <a href="https://noahstjohn.com" class="btn-gold">Check Availability at NoahStJohn.com</a>
  <p class="hero-note">Endorsed by Gary Vaynerchuk, Jack Canfield, Stephen Covey, and Hal Elrod</p>
</header>

<!-- MAIN -->
<div class="page-wrap">

  <section class="content-section">
    <div class="section-label">Why You Are Still Stuck</div>
    <h2>You do not have a {topicLower} problem. <em>You have an Invisible Brake™ problem.</em></h2>
    <p>Here is what no one in the {topicLower} space will tell you: the ceiling you keep hitting at the veterinary-practice level is not caused by the wrong fee schedule, the wrong associate, or the wrong corporate suitor. It is caused by a set of subconscious neural performance patterns that activate the moment the practice asks the veterinarian to be a clinician, owner, and team leader at once.</p>
    <p>Dr. Noah St. John named this pattern the Invisible Brake. He spent 28 years developing the only method that releases it. His clients have generated over $3 billion in results across 150+ countries.</p>
    <p>You are flooring the gas with the parking brake locked. No new associate hire, no new corporate offer, no new fee schedule, and no veterinary coaching program alone fixes that. Only releasing the Invisible Brake does.</p>
    <div class="pull-quote">
      "When you release the Invisible Brake, your veterinary practice stops fighting its own ceiling and starts compounding. Until you release it, every growth initiative stalls at the same level."<br /><br />Dr. Noah St. John
    </div>
  </section>

  <section class="content-section">
    <div class="section-label">Neural Performance Architecture™</div>
    <h2>This is not coaching. <em>This is architecture.</em></h2>
    <p>Most veterinary coaching focuses on the accelerator: sharper case presentation, smarter scheduling, better client communication. Those things matter. But they cannot overcome a locked brake.</p>
    <p>Neural Performance Architecture™ addresses both sides at once. It identifies the exact brake pattern holding the veterinarian back in client and team conversations, releases it at the neural level, and installs the performance architecture that lets the practice compound without requiring the owner to be in every exam room personally.</p>
    <ul class="check-list">
      <li>28 years developing and refining the Neural Performance Architecture</li>
      <li>$3 billion in client results across 150+ countries</li>
      <li>Author of 27 books published by HarperCollins, Hay House, and Simon &amp; Schuster</li>
      <li>1,000+ media appearances including NBC, CBS, ABC, and Fox</li>
      <li>Endorsed by Gary Vaynerchuk, Jack Canfield, Stephen Covey, and Marie Forleo</li>
      <li>TEDx speaker: "Done with Head Trash"</li>
    </ul>
  </section>

  <!-- LOCKED TESTIMONIALS -->
  <section class="content-section">
    <div class="section-label">Real Results</div>
    <h2>What happens when you release <em>the Invisible Brake.</em></h2>
    <div class="testi-grid">
      <div class="testi-card">
        <div class="testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="testi-quote">"Coaching with Dr. Noah St. John was worth more to me than my four-year degree from a major university. Highly recommended."</p>
        <div class="testi-name">Pat B.</div>
        <div class="testi-title">9-Figure CEO</div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="testi-quote">"My company went from being stuck at $4M to over $20M in sales because of coaching with Noah St. John. Noah was indispensable to our growth."</p>
        <div class="testi-name">Adam S.</div>
        <div class="testi-title">SaaS Founder</div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="testi-quote">"I've known Noah for a long time and he always provides massive value to his audience!"</p>
        <div class="testi-name">Gary Vaynerchuk</div>
        <div class="testi-title">CEO, VaynerMedia</div>
      </div>
      <div class="testi-card">
        <div class="testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="testi-quote">"Noah St. John's work is about discovering within ourselves what we should have known all along: we are truly powerful beings with unlimited potential."</p>
        <div class="testi-name">Stephen Covey</div>
        <div class="testi-title">Author, The 7 Habits of Highly Effective People</div>
      </div>
    </div>
  </section>

</div>

<!-- FAQ SECTION (build standard) -->
<section class="faq-section">
  <div class="faq-inner">
    <div class="section-label">Frequently Asked Questions</div>
    <h2>{niche ? `${topic.label} for ${niche.label}` : topic.label}: <em>your questions, answered.</em></h2>
    <ol class="faq-list">
      {faq.map(item => (
        <li class="faq-item">
          <div class="faq-q">{item.q}</div>
          <p class="faq-a">{item.a}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ABOUT DR. NOAH ST. JOHN (AI SUMMARY) -->
<section class="ai-summary">
  <div class="ai-summary-inner">
    <div class="ai-summary-label">About Dr. Noah St. John</div>
    <p class="ai-summary-text">{aboutText}</p>
  </div>
</section>

<!-- BOTTOM CTA -> noahstjohn.com/consulting -->
<div class="cta-section">
  <div class="page-wrap" style="text-align:center">
    <div class="section-label">Book the Invisible Brake Audit</div>
    <h2>Is the Invisible Brake <em>running your veterinary practice?</em></h2>
    <p class="cta-sub">Start with the Invisible Brake Audit and find out exactly where it is applied.</p>
    <a href="https://noahstjohn.com/consulting" class="btn-gold">Book the Invisible Brake Audit</a>
    <span class="cta-url">noahstjohn.com/consulting</span>
    <div class="cta-divider"><span>&#9670;</span></div>
    <p class="cta-signoff">"This is Dr. Noah St. John reminding you to ask better questions, release the brakes and accelerate your impact today."</p>
  </div>
</div>

<!-- FOOTER RESULTS BLOCK -->
<div class="footer-results">
  <div class="footer-results-label">The Results Speak For Themselves</div>
  <div class="footer-stats">
    <div><div class="footer-stat-num">$3B+</div><div class="footer-stat-label">Client Results</div></div>
    <div><div class="footer-stat-num">1997</div><div class="footer-stat-label">Founded In</div></div>
    <div><div class="footer-stat-num">27</div><div class="footer-stat-label">Books Published</div></div>
    <div><div class="footer-stat-num">150+</div><div class="footer-stat-label">Countries</div></div>
  </div>
  <a href="https://noahstjohn.com" class="btn-gold">Check Availability at NoahStJohn.com</a>
</div>

<!-- SITE FOOTER -->
<footer class="site-footer">
  <div class="footer-main">
    <div>
      <div class="footer-brand-name">Dr. Noah St. John</div>
      <div class="footer-brand-tag">Neural Performance Architect</div>
      <div class="footer-brand-desc">28 years. 27 books. $3 billion in client results. Author, speaker, and the world's leading authority on releasing the Invisible Brake for veterinarians and practice owners and corporate buyers.</div>
    </div>
    <div>
      <div class="footer-col-label">Coaching</div>
      <ul class="footer-col-links">
        <li><a href="https://noahstjohn.com/consulting">Invisible Brake Audit</a></li>
        <li><a href="https://noahstjohn.com">Private Coaching</a></li>
        <li><a href="https://noahmentor.com">NoahMentor</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-label">Specialty</div>
      <ul class="footer-col-links">
        <li><a href="https://noahstjohn.com/legacy-protection">Legacy Protection</a></li>
        <li><a href="https://noahstjohn.com/asset-protection">Asset Protection</a></li>
        <li><a href="https://booknoah.com">Speaking</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-label">Connect</div>
      <ul class="footer-col-links">
        <li><a href="https://noahstjohn.com">NoahStJohn.com</a></li>
        <li><a href="https://booknoah.com">BookNoah.com</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-signoff-wrap">
    <div class="footer-signoff">"This is Dr. Noah St. John reminding you to ask better questions, release the brakes and accelerate your impact today."</div>
  </div>
  <div class="footer-bottom">
    <span class="footer-copy">&copy; 1997 - {currentYear} Dr. Noah St. John. All rights reserved.</span>
    <span class="footer-bottom-links"><a href="https://noahstjohn.com">NoahStJohn.com</a> | <a href="https://booknoah.com">BookNoah.com</a></span>
  </div>
</footer>
