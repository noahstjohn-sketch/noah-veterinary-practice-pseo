---
// src/pages/[topic]/[niche].astro
// Static mode: prerenders one page per (atomic topic) x niche.
// Longtail topics (including vs comparisons): no cross pages emitted.
// AEO schemas: Service + BreadcrumbList. No Article on cross pages.
import Base from '../../layouts/Base.astro';
import PageTemplate from '../../components/PageTemplate.astro';
import { topics } from '../../data/topics.js';
import { niches } from '../../data/niches.js';
import { buildPageData } from '../../lib/page-data.js';

const BUYER_SINGULAR = 'veterinarian-owner';

// Force prerender even when astro.config has output:'server' (legacy SSR sites).
export const prerender = true;

export async function getStaticPaths() {
  const paths = [];
  for (const topic of topics) {
    if (topic.kind !== 'atomic') continue;
    for (const niche of niches) {
      paths.push({
        params: { topic: topic.slug, niche: niche.slug },
        props: { topic, niche },
      });
    }
  }
  return paths;
}

const { topic, niche } = Astro.props;
if (!topic || !niche) return new Response(null, { status: 404 });

const { faq, faqSchema, aboutText } = buildPageData(topic, niche, { buyerSingular: BUYER_SINGULAR });

const title = `${topic.label} for ${niche.label} | Dr. Noah St. John | Neural Performance Architect`;
const description = `${topic.label} for ${niche.label}: Release the Invisible Brake capping veterinarian-owners. Dr. Noah St. John. 28 years. $3 billion in client results.`;
const canonical = `https://veterinary-practice.noahstjohn.com/${topic.slug}/${niche.slug}`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${topic.label} for ${niche.label}`,
  description: `${topic.label} for ${niche.label}. Dr. Noah St. John, Neural Performance Architect.`,
  serviceType: topic.label,
  provider: {
    '@type': 'Person',
    name: 'Dr. Noah St. John',
    jobTitle: 'Neural Performance Architect',
    url: 'https://noahstjohn.com',
    sameAs: ['https://noahstjohn.com', 'https://booknoah.com'],
  },
  areaServed: { '@type': 'Place', name: 'Worldwide' },
  audience: { '@type': 'Audience', audienceType: niche.label },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://veterinary-practice.noahstjohn.com/' },
    { '@type': 'ListItem', position: 2, name: topic.label, item: `https://veterinary-practice.noahstjohn.com/${topic.slug}/` },
    { '@type': 'ListItem', position: 3, name: niche.label, item: canonical + '/' },
  ],
};

const extraSchemas = [serviceSchema, breadcrumbSchema];
---
<Base title={title} description={description} canonical={canonical} faqSchema={faqSchema} extraSchemas={extraSchemas} ogType="article">
  <PageTemplate topic={topic} niche={niche} faq={faq} aboutText={aboutText} />
</Base>
